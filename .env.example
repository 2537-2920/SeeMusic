#需要新建一个.env文件，并将以下内容复制到其中，修改相应的值后保存即可

# SSH connection
SSH_HOST=175.24.130.34
SSH_USER=ubuntu
SSH_PORT=22
SSH_KEY_FILE=C:/Users/your-user/.ssh/id_cloud_server

# MySQL connection on the remote host
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB_NAME=SeeMusic

# Backend runtime database configuration
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=seemusic_app
DB_PASSWORD=
DB_NAME=SeeMusic
REFERENCE_AUDIO_REMOTE_DIR=/srv/seemusic/storage/reference_audio

# Dump and remote workspace
MYSQL_DUMP_INPUT=SeeMusic
MYSQL_DUMP_OUTPUT=SeeMusic.safe.sql
MYSQL_REMOTE_DIR=/tmp/seemusic_migration

# Optional flags: 1=true, 0=false
MYSQL_KEEP_REMOTE_FILES=0
MYSQL_SKIP_VERIFY=0
